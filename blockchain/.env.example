# Environment variables — copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Your MetaMask wallet private key (for deployment)
PRIVATE_KEY=your_private_key_here

# RPC URLs — get from Alchemy or Infura
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
GOERLI_RPC_URL=https://eth-goerli.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Etherscan API key for contract verification (optional)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Enable gas reporting (true/false)
REPORT_GAS=false
